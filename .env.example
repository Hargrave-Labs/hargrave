VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production

# Client Portal — Supabase (Project → Settings → API)
# VITE_SUPABASE_ANON_KEY holds the browser-safe "publishable" key (sb_publishable_...),
# NOT the sb_secret_... key. It is protected by Row-Level Security.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
